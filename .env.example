# Database — transaction pooler URL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fireslot?schema=public"
SLOW_QUERY_MS=500

# Backend (apps/api)
JWT_SECRET="replace-with-strong-secret"
JWT_EXPIRES_IN="7d"
PORT=4000
UPLOAD_DIR="./uploads"
CORS_ORIGINS="http://localhost:3000,https://esport-web-rho.vercel.app"
ADMIN_EMAIL="admin@fireslot.np"
ADMIN_PASSWORD="Admin@123"
GOOGLE_CLIENT_ID="714502041613-f02qutfrv00gj87fr1hptgcgctp62i31.apps.googleusercontent.com"

# Supabase (storage + realtime broadcast on the API side)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="service-role-key"
SUPABASE_BUCKET="uploads"

# Frontend (apps/web)
# Use an HTTPS API URL in production and APK builds.
NEXT_PUBLIC_API_URL="http://localhost:4000/api"
NEXT_PUBLIC_GOOGLE_CLIENT_ID="714502041613-f02qutfrv00gj87fr1hptgcgctp62i31.apps.googleusercontent.com"
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="anon-public-key"

# Android APKs load bundled static files by default.
# Leave CAPACITOR_SERVER_URL unset in production. Set only for local live reload.
# CAPACITOR_SERVER_URL="http://192.168.1.10:3000"
