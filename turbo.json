{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "DATABASE_URL",
        "JWT_SECRET",
        "JWT_EXPIRES_IN",
        "PORT",
        "UPLOAD_DIR",
        "CORS_ORIGINS",
        "ADMIN_EMAIL",
        "ADMIN_PASSWORD",
        "CAPACITOR_BUILD",
        "CAPACITOR_SERVER_URL",
        "NEXT_PUBLIC_API_URL",
        "NEXT_PUBLIC_GOOGLE_CLIENT_ID",
        "NEXT_PUBLIC_IS_NATIVE",
        "NEXT_PUBLIC_SUPABASE_ANON_KEY",
        "NEXT_PUBLIC_SUPABASE_URL"
      ],
      "outputs": [".next/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "generate": {
      "cache": false
    }
  }
}
